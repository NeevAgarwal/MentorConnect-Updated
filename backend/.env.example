PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/mentorconnect

# Required for protected APIs (generate a long random string)
JWT_SECRET=change_this_to_a_long_random_secret

# Firebase ID token verification (tokeninfo audience). Comma-separated if multiple.
FIREBASE_PROJECT_ID=ideasphere-web
# FIREBASE_AUDIENCES=ideasphere-web,your-oauth-client-id.apps.googleusercontent.com

# Comma-separated admin emails (matched on signup / existing user email)
ADMIN_EMAILS=you@example.com

# Optional SMTP (booking & welcome emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="MentorConnect <noreply@example.com>"

# CORS (comma-separated origins). Leave unset for same-machine dev.
# CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500

# RATE_LIMIT_MAX=400
